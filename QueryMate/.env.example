# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/query_mate
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# JWT Secret Key
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_TOKENS=2048
GEMINI_PROJECT_ID=querymate-ai

# Crypto Secret for password encryption
CRYPTO_SECRET=your_crypto_secret_here

# CORS Configuration (comma-separated for multiple origins)
# Example: http://localhost:5173,https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Query Execution Settings
QUERY_MAX_ROWS=1000
QUERY_TIMEOUT_SECONDS=30
QUERY_ALLOW_MODIFICATIONS=true
